# Canton Conformance Kit — Infrastructure Configuration
# This is the single source of truth for Canton version and network settings.

# Canton/Splice Docker image version
CANTON_VERSION=0.5.3

# Image registry
IMAGE_REPO=ghcr.io/digital-asset/decentralized-canton-sync/docker/

# PostgreSQL
POSTGRES_VERSION=14
DB_USER=cnadmin
DB_PASSWORD=supersafe
DB_SERVER=postgres
DB_PORT=5432

# Validator profiles (all enabled for conformance testing)
SV_PROFILE=on
APP_PROVIDER_PROFILE=on
APP_USER_PROFILE=on

# Port suffixes — validators are exposed as {prefix}{suffix}
# prefix: 2=app-user, 3=app-provider, 4=sv
PARTICIPANT_LEDGER_API_PORT_SUFFIX=901
PARTICIPANT_ADMIN_API_PORT_SUFFIX=902
PARTICIPANT_JSON_API_PORT_SUFFIX=975
VALIDATOR_ADMIN_API_PORT_SUFFIX=903
CANTON_HTTP_HEALTHCHECK_PORT_SUFFIX=900
CANTON_GRPC_HEALTHCHECK_PORT_SUFFIX=961

# Docker network
DOCKER_NETWORK=canton-conformance

# Splice environment
SPLICE_SV_IS_DEVNET=true
SPLICE_APP_UI_NETWORK_NAME=Splice
SPLICE_APP_UI_NETWORK_FAVICON_URL=https://www.hyperledger.org/hubfs/hyperledgerfavicon.png
SPLICE_APP_UI_AMULET_NAME=Amulet
SPLICE_APP_UI_AMULET_NAME_ACRONYM=AMT
SPLICE_APP_UI_NAME_SERVICE_NAME=Amulet Name Service
SPLICE_APP_UI_NAME_SERVICE_NAME_ACRONYM=ANS

# Splice validator config
TARGET_TRAFFIC_THROUGHPUT=20000
MIN_TRAFFIC_TOPUP_INTERVAL=1m
SPLICE_APP_VALIDATOR_SV_SPONSOR_ADDRESS=http://localhost:5014
SPLICE_APP_VALIDATOR_SCAN_ADDRESS=http://localhost:5012
APP_PROVIDER_VALIDATOR_ONBOARDING_SECRET=app-provider-validator-onboarding-secret
APP_USER_VALIDATOR_ONBOARDING_SECRET=app-user-validator-onboarding-secret
MIGRATION_ID=0
LATEST_PACKAGES_ONLY=true

# Party hints
PARTY_HINT=conformance-kit-1
APP_PROVIDER_PARTY_HINT=app_provider_conformance-kit-1
APP_USER_PARTY_HINT=app_user_conformance-kit-1

# Auth (unsafe/dev mode for local conformance testing)
AUTH_SV_AUDIENCE=https://canton.network.global
AUTH_SV_VALIDATOR_USER_NAME=ledger-api-user
AUTH_SV_WALLET_ADMIN_USER_NAME=sv
AUTH_APP_PROVIDER_AUDIENCE=https://canton.network.global
AUTH_APP_PROVIDER_VALIDATOR_USER_NAME=ledger-api-user
AUTH_APP_PROVIDER_WALLET_ADMIN_USER_NAME=app-provider
AUTH_APP_USER_AUDIENCE=https://canton.network.global
AUTH_APP_USER_VALIDATOR_USER_NAME=ledger-api-user
AUTH_APP_USER_WALLET_ADMIN_USER_NAME=app-user
SPLICE_APP_VALIDATOR_LEDGER_API_AUTH_AUDIENCE=https://canton.network.global
SPLICE_APP_UI_AUTH_AUDIENCE=https://sv.example.com
SPLICE_APP_VALIDATOR_AUTH_AUDIENCE=https://sv.example.com
SPLICE_APP_UI_UNSAFE=true
SPLICE_APP_UI_UNSAFE_SECRET=unsafe
SPLICE_APP_UI_HTTP_URL=true
